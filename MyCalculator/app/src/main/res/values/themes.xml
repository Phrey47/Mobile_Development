<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.MyCalculator" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="materialButtonStyle">@style/RoundButton</item>
    </style>

    <style name="Theme.MyCalculator" parent="Base.Theme.MyCalculator" />

    <style name="RoundButton" parent="Widget.Material3.Button.UnelevatedButton">
        <item name="shapeAppearanceOverlay">@style/ShapeRound</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ShapeRound">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

</resources>